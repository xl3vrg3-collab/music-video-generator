# LUMN Studio Environment Variables
# Copy this to .env and fill in your API keys

# Required: At least one video generation API
RUNWAY_API_KEY=your_runway_api_key_here

# Optional: AI auto-fill (character descriptions, prompt enhancement)
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: Voice cloning
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Optional: Music generation
SUNO_API_KEY=your_suno_key_here

# Optional: xAI Grok video generation
XAI_API_KEY=your_xai_key_here

# Server port (Railway sets this automatically)
PORT=3849
